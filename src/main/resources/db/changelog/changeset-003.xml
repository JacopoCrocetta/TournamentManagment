<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="003" author="SeniorArchitect">
        <addColumn tableName="matches">
            <column name="next_match_id" type="uuid">
                <constraints foreignKeyName="fk_match_next_match" referencedTableName="matches" referencedColumnNames="id"/>
            </column>
            <column name="position_in_next_match" type="int"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
